{
  "name": "avrostream-js",
  "version": "0.1.0",
  "description": "Transparent Avro binary transport layer for JavaScript — drop-in fetch/WebSocket replacement that encodes JSON as Avro on the wire.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "bin": {
    "avro-gen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "bench:stream": "node scripts/benchmark-stream-decoder.mjs",
    "bench:avro-vs-json": "node scripts/benchmark-avro-vs-json.mjs",
    "bench:avro-vs-json:gc": "node --expose-gc scripts/benchmark-avro-vs-json.mjs",
    "bench:avro-vs-json:release": "OUTPUT_DIR=benchmark-results/avro-vs-json/release SCENARIOS=20000,50000,100000 WARMUP_ROUNDS=3 ROUNDS=10 node --expose-gc scripts/benchmark-avro-vs-json.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "avro",
    "binary",
    "serialization",
    "fetch",
    "websocket",
    "transport",
    "streaming",
    "performance"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/avrostream/avrostream-js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "avsc": "^5.7.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^8.56.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.3"
  }
}
